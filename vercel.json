{
  "version": 2,
  "buildCommand": null,
  "installCommand": null,
  "devCommand": "npm run dev",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/javascript; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
